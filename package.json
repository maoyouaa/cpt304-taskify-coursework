  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DSCKGEC/Taskify/issues"
  },
  "homepage": "https://github.com/DSCKGEC/Taskify#readme",
  "devDependencies": {
    "c8": "^10.1.3",
    "jsdom": "^26.1.0",
    "nodemon": "^2.0.19",
    "supertest": "^7.1.1"
  },
  "dependencies": {
    "dotenv": "^16.0.1",
    "ejs": "^3.1.8",
    "express": "^4.18.1"
  }
}
