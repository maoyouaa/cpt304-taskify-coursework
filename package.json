{
  "name": "taskify",
  "version": "1.0.0",
  "description": "Research-led enhancement of Taskify with accessible task planning, i18n, consent handling, and automated tests.",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node --test tests/**/*.test.mjs",
    "test:watch": "node --test --watch tests/**/*.test.mjs",
    "coverage": "c8 --reporter=text --reporter=html --reporter=lcov node --test tests/**/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DSCKGEC/Taskify.git"
  },
  "keywords": [],
