<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/static/styles/main.css" />
  </head>
  <body data-page="<%= pageName %>">
    <%- include("partials/site-header", { pageName }) %>

    <main class="section-band">
      <div class="container auth-layout">
        <section class="auth-copy" aria-labelledby="auth-heading">
          <p class="eyebrow" data-i18n="signup.eyebrow">Workspace setup</p>
          <h1 id="auth-heading" data-i18n="signup.title">Start with a focused task space.</h1>
          <p class="lede" data-i18n="signup.subtitle">
            This lightweight onboarding page exists so the project keeps a coherent entry flow while the main task
            management experience lives in the dashboard.
          </p>
          <ul class="signal-list">
            <li data-i18n="signup.pointOne">Labelled inputs and keyboard-safe focus order</li>
            <li data-i18n="signup.pointTwo">No hidden HTML injection path through the form</li>
            <li data-i18n="signup.pointThree">Clear redirect to the working dashboard after submit</li>
          </ul>
        </section>

        <section class="auth-card" aria-label="Workspace start form">
          <form action="/signup" method="post" class="auth-form">
            <div class="field">
              <label for="name" data-i18n="signup.nameLabel">Name</label>
              <input id="name" name="name" type="text" maxlength="60" required />
            </div>
            <div class="field">
              <label for="email" data-i18n="signup.emailLabel">Email</label>
              <input id="email" name="email" type="email" maxlength="80" required />
            </div>
            <div class="field">
              <label for="team" data-i18n="signup.teamLabel">Team</label>
              <input id="team" name="team" type="text" maxlength="40" />
            </div>
            <button class="button button-primary button-full" type="submit" data-i18n="signup.primaryAction">
              Continue to dashboard
            </button>
          </form>

          <div class="auth-divider" aria-hidden="true"></div>

          <form action="/login" method="post" class="auth-form auth-form-muted">
            <div class="field">
              <label for="login-email" data-i18n="signup.loginEmailLabel">Email</label>
              <input id="login-email" name="email" type="email" maxlength="80" required />
            </div>
            <div class="field">
              <label for="login-password" data-i18n="signup.passwordLabel">Password</label>
              <input id="login-password" name="password" type="password" minlength="8" maxlength="80" required />
            </div>
            <button class="button button-secondary button-full" type="submit" data-i18n="signup.secondaryAction">
              Return to dashboard
            </button>
          </form>
        </section>
      </div>
    </main>

    <%- include("partials/site-footer") %>
    <%- include("partials/cookie-banner") %>
    <script type="module" src="/static/js/site.js"></script>
  </body>
</html>
