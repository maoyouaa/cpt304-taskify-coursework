<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/static/styles/main.css" />
  </head>
  <body data-page="<%= pageName %>">
    <%- include("partials/site-header", { pageName }) %>

    <main>
      <section class="hero-band">
        <div class="container hero-grid">
          <div class="hero-copy">
            <p class="eyebrow" data-i18n="home.eyebrow">Research-led coursework build</p>
            <h1 data-i18n="home.title">A calmer way to organise daily work.</h1>
            <p class="lede" data-i18n="home.subtitle">
              Taskify turns the original static prototype into an accessible planning space with saved tasks,
              bilingual UI, and privacy-aware defaults.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="/dashboard" data-i18n="home.primaryAction">Open dashboard</a>
              <a class="button button-secondary" href="/privacy" data-i18n="home.secondaryAction">Read privacy policy</a>
            </div>
            <ul class="signal-list" aria-label="Key product signals">
              <li data-i18n="home.signalOne">Accessible keyboard-first layout</li>
              <li data-i18n="home.signalTwo">Persistent task board with search and priorities</li>
              <li data-i18n="home.signalThree">English and Chinese interface toggle</li>
            </ul>
          </div>

          <section class="preview-shell" aria-labelledby="preview-heading">
            <div class="preview-topbar">
              <span class="dot"></span>
              <span class="dot"></span>
              <span class="dot"></span>
            </div>
            <div class="preview-body">
              <div>
                <p class="mini-label" data-i18n="home.previewLabel">Today</p>
                <h2 id="preview-heading" data-i18n="home.previewTitle">Coursework sprint board</h2>
              </div>
              <div class="preview-metrics">
                <article>
                  <span data-i18n="home.previewMetricOneLabel">Planned</span>
                  <strong>5</strong>
                </article>
                <article>
                  <span data-i18n="home.previewMetricTwoLabel">In progress</span>
                  <strong>2</strong>
                </article>
                <article>
                  <span data-i18n="home.previewMetricThreeLabel">Done</span>
                  <strong>7</strong>
                </article>
              </div>
              <div class="preview-list" aria-label="Preview tasks">
                <article class="preview-task">
                  <span class="priority-chip priority-high" data-i18n="priority.high">High</span>
                  <h3 data-i18n="home.previewTaskOneTitle">Audit accessibility defects</h3>
                  <p data-i18n="home.previewTaskOneBody">Run Lighthouse and capture before screenshots for the report.</p>
                </article>
                <article class="preview-task">
                  <span class="priority-chip priority-medium" data-i18n="priority.medium">Medium</span>
                  <h3 data-i18n="home.previewTaskTwoTitle">Implement bilingual interface</h3>
                  <p data-i18n="home.previewTaskTwoBody">Externalise copy and keep language choice between visits.</p>
                </article>
              </div>
            </div>
          </section>
        </div>
      </section>

      <section class="section-band">
        <div class="container info-grid">
          <article class="info-panel">
            <p class="eyebrow" data-i18n="home.qualityEyebrow">Why this version scores better</p>
            <h2 data-i18n="home.qualityTitle">Built to demonstrate the four deficiencies.</h2>
            <p data-i18n="home.qualityBody">
              The upgraded flow shows evidence for accessibility, persistence, validation, and user feedback without
              drifting into feature bloat.
            </p>
          </article>
          <article class="info-panel checklist-panel">
            <h2 data-i18n="home.baselineTitle">Baseline-ready areas</h2>
            <ul class="checklist">
              <li data-i18n="home.baselineOne">Deployable Express app structure</li>
              <li data-i18n="home.baselineTwo">Cookie consent and privacy policy page</li>
              <li data-i18n="home.baselineThree">Automated route and logic tests for coverage</li>
            </ul>
          </article>
        </div>
      </section>
    </main>

    <%- include("partials/site-footer") %>
    <%- include("partials/cookie-banner") %>
    <script type="module" src="/static/js/site.js"></script>
  </body>
</html>
